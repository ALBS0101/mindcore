# Configuração do Firebase (cliente). Copie para `.env.local` e preencha.
# Estes valores são da config WEB do Firebase — públicos por natureza, mas
# mantidos fora do repositório. A segurança real vem das Firestore Security
# Rules + restrição da API key no Google Cloud Console (HTTP referrers).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Liga o fluxo de pagamento real (Mercado Pago). Só ative depois de fazer o
# deploy das Cloud Functions e configurar o MP_ACCESS_TOKEN. "true" para ligar.
VITE_PAYMENTS_ENABLED=false

# Chave PÚBLICA do Mercado Pago (cliente) — usada pelo MP.js/Brick do cartão.
# É pública por natureza (pode ir ao bundle). O Access Token (secreto) NUNCA.
VITE_MP_PUBLIC_KEY=
