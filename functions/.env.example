# Credenciais do Mercado Pago (NUNCA vão para o cliente nem para o git).
# Copie para functions/.env e preencha. Em produção, prefira definir como
# secret: `firebase functions:secrets:set MP_ACCESS_TOKEN`.

# Access Token PRODUÇÃO (Checkout Transparente) — Mercado Pago > Suas integrações
MP_ACCESS_TOKEN=

# (Opcional) Segredo para validar a assinatura do webhook (x-signature)
MP_WEBHOOK_SECRET=

# Preço do relatório (R$). Default 19.90 se vazio.
MINDCODE_PRICE=19.90
