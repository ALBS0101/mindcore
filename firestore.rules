rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Cobranças PIX. O cliente só LÊ o status do seu pagamento pelo id
    // (id do Mercado Pago, não-adivinhável). NINGUÉM grava pelo cliente —
    // apenas as Cloud Functions (admin SDK) escrevem o status. Isso impede
    // que alguém falsifique "approved" e libere o relatório sem pagar.
    match /payments/{paymentId} {
      allow get: if true;
      allow list, create, update, delete: if false;
    }

    // PII (email/nome) — NUNCA legível pelo cliente. Só as Cloud Functions
    // (admin SDK) acessam. Mantém os dados pessoais fora do alcance público.
    match /payment_private/{paymentId} {
      allow read, write: if false;
    }

    // Bloqueia o resto por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
